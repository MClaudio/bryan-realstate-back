generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  username  String   @unique
  email     String   @unique
  password  String   @map("password_hash")
  phone     String?
  address   String?
  ruc       String   @unique
  type      UserType
  hasChangedDefaultPassword Boolean @default(false) @map("has_changed_default_password")
  isActive Boolean @default(true) @map("is_active")
  resetPasswordToken String? @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients    Client[]
  properties Property[]
  notifications Notification[]

  @@map("users")
}

enum NotificationActionType {
  NAVIGATE
  OPEN_MODAL
}

model Client {
  id        String    @id @default(uuid()) @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String?
  password  String?   @map("password_hash")
  phone     String
  address   String?
  ruc       String?
  birthDate DateTime? @map("birth_date") @db.Date
  googleContactId String?   @unique @map("google_contact_id")
  googleSyncedAt  DateTime? @map("google_synced_at")
  userId    String?   @map("user_id") @db.Uuid
  lastLogin Boolean   @default(false) @map("last_login")
  notes                String?   @map("notes")
  interestDescription  String?   @map("interest_description")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User?     @relation(fields: [userId], references: [id])
  interests PropertyInterest[]
  negotiatedProperties Property[]

  @@map("clients")
}

model Property {
  id                String         @id @default(uuid()) @db.Uuid
  code              String
  address           String
  locationUrl       String         @map("location_url")
  constructionArea  Decimal        @map("construction_area") @db.Decimal(10, 2)
  landArea          Decimal        @map("land_area") @db.Decimal(10, 2)
  hasBasicServices  Boolean        @default(false) @map("has_basic_services")
  basicServices     Json           @map("basic_services")
  features          String?
  propertyType      PropertyType   @map("property_type")
  constructionYears Int?           @map("construction_years")
  latitude          Decimal        @db.Decimal(10, 8)
  longitude         Decimal        @db.Decimal(11, 8)
  topography        Topography
  zone              Zone
  cityTime          Int?           @map("city_time")
  observations      String?
  status            PropertyStatus @default(Nuevo)
  advisorId         String         @map("advisor_id") @db.Uuid
  owner             String?
  price             Decimal        @db.Decimal(12, 2)
  maxPrice          Decimal?       @map("max_price") @db.Decimal(12, 2)
  minPrice          Decimal        @map("min_price") @db.Decimal(12, 2)
  commission        Decimal        @db.Decimal(5, 2)
  salePrice         Decimal?       @map("sale_price") @db.Decimal(12, 2)
  isPublic          Boolean        @default(true) @map("is_public")
  facebookUrl       String?        @map("facebook_url")
  tiktokUrl         String?        @map("tiktok_url")
  instagramUrl      String?        @map("instagram_url")
  youtubeUrl        String?        @map("youtube_url")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  isActive              Boolean        @default(true) @map("is_active")
  isFeatured            Boolean        @default(false) @map("is_featured")
  negotiationClientId   String?        @map("negotiation_client_id") @db.Uuid
  advisor               User           @relation(fields: [advisorId], references: [id])
  negotiationClient     Client?        @relation(fields: [negotiationClientId], references: [id])
  files                 PropertyFile[]
  processes             Process[]
  interests             PropertyInterest[]

  @@index([code])
  @@map("properties")
}

model File {
  id            String         @id @default(uuid()) @db.Uuid
  originalName  String         @map("original_name")
  fileName      String         @map("file_name")
  path          String
  size          Int
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  configuration Configuration?
  propertyFiles PropertyFile[]
  processFiles  ProcessFile[]

  @@map("files")
}

model Configuration {
  id               String   @id @default(uuid()) @db.Uuid
  logoId           String?  @unique @map("logo_id") @db.Uuid
  companyName      String   @map("company_name")
  businessName     String   @map("business_name")
  ruc              String
  phone            String
  email            String?
  facebookProfile  String?  @map("facebook_profile")
  instagramProfile String?  @map("instagram_profile")
  youtubeProfile   String?  @map("youtube_profile")
  whatsappLink     String?  @map("whatsapp_link")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  logo             File?    @relation(fields: [logoId], references: [id])

  @@map("configurations")
}

model PropertyFile {
  propertyId String   @map("property_id") @db.Uuid
  fileId     String   @map("file_id") @db.Uuid
  fileType   FileType @map("file_type")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, fileId])
  @@map("property_files")
}

enum UserType {
  ADMIN
  ACCOUNTING
  EMPLOYEE
}

enum PropertyType {
  Casa
  Terreno
  Casa_y_terreno @map("Casa y terreno")
  Departamento
  Finca
  Lote
}

enum Topography {
  Plano
  Semiplano
  Pendiente
  Mixto
}

enum Zone {
  Rural
  Urbano
  Urbanizacion @map("Urbanización")
}

enum PropertyStatus {
  Nuevo
  Negociacion @map("Negociación")
  Vendido
}

enum FileType {
  image
  document
}

model Process {
  id              String        @id @default(uuid()) @db.Uuid
  propertyId      String        @map("property_id") @db.Uuid
  title           String
  type            ProcessType
  description     String
  expenses        Json          @default("[]")
  approximateTime String?       @map("approximate_time")
  nextStep        String?       @map("next_step")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  files           ProcessFile[]

  @@map("processes")
}

model ProcessFile {
  processId String   @map("process_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@id([processId, fileId])
  @@map("process_files")
}

enum ProcessType {
  Comprador
  Vendedor
}

model Blacklist {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blacklist")
}

enum InterestLevel {
  Bajo
  Medio
  Alto
  MuyAlto @map("Muy Alto")
}

model PropertyInterest {
  id            String        @id @default(uuid()) @db.Uuid
  propertyId    String        @map("property_id") @db.Uuid
  clientId      String        @map("client_id") @db.Uuid
  interestDate  DateTime      @map("interest_date") @db.Date
  interestLevel InterestLevel @map("interest_level")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("property_interests")
}

model GoogleAuthToken {
  id           String   @id @default(uuid()) @db.Uuid
  provider     String   @unique @default("google")
  accessToken  String   @map("access_token")
  refreshToken String?  @map("refresh_token")
  tokenType    String?  @map("token_type")
  scope        String?
  expiryDate   DateTime? @map("expiry_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("google_auth_tokens")
}

model ContactSyncExclusion {
  id              String   @id @default(uuid()) @db.Uuid
  candidateId     String?  @unique @map("candidate_id")
  googleContactId String?  @unique @map("google_contact_id")
  email           String?
  phone           String?
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([phone])
  @@map("contact_sync_exclusions")
}

model ContactSyncLog {
  id                String   @id @default(uuid()) @db.Uuid
  direction         String
  importedCount     Int      @default(0) @map("imported_count")
  duplicateCount    Int      @default(0) @map("duplicate_count")
  excludedCount     Int      @default(0) @map("excluded_count")
  invalidCount      Int      @default(0) @map("invalid_count")
  details           Json?    @map("details")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("contact_sync_logs")
}

model Notification {
  id         String                 @id @default(uuid()) @db.Uuid
  userId     String                 @map("user_id") @db.Uuid
  title      String
  message    String
  path       String?
  actionType NotificationActionType @default(NAVIGATE) @map("action_type")
  modalKey   String?                @map("modal_key")
  entityType String?                @map("entity_type")
  entityId   String?                @map("entity_id")
  payload    Json?
  isRead     Boolean                @default(false) @map("is_read")
  readAt     DateTime?              @map("read_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}
