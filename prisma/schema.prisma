generator client {
  provider   = "prisma-client-js"

  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  username  String   @unique
  email     String   @unique
  password  String   @map("password_hash")
  phone     String?
  address   String?
  ruc       String   @unique
  type      UserType
  hasChangedDefaultPassword Boolean @default(false) @map("has_changed_default_password")
  resetPasswordToken String? @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients    Client[]
  properties Property[]

  @@map("users")
}

model Client {
  id        String    @id @default(uuid()) @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String?
  password  String?   @map("password_hash")
  phone     String
  address   String?
  ruc       String?
  birthDate DateTime? @map("birth_date") @db.Date
  userId    String?   @map("user_id") @db.Uuid
  lastLogin Boolean   @default(false) @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User?     @relation(fields: [userId], references: [id])

  @@map("clients")
}

model Property {
  id                String         @id @default(uuid()) @db.Uuid
  code              String
  address           String
  locationUrl       String         @map("location_url")
  constructionArea  Decimal        @map("construction_area") @db.Decimal(10, 2)
  landArea          Decimal        @map("land_area") @db.Decimal(10, 2)
  hasBasicServices  Boolean        @default(false) @map("has_basic_services")
  basicServices     Json           @map("basic_services")
  features          String?
  propertyType      PropertyType   @map("property_type")
  constructionYears Int?           @map("construction_years")
  latitude          Decimal        @db.Decimal(10, 8)
  longitude         Decimal        @db.Decimal(11, 8)
  topography        Topography
  zone              Zone
  cityTime          Int?           @map("city_time")
  observations      String?
  status            PropertyStatus @default(Nuevo)
  advisorId         String         @map("advisor_id") @db.Uuid
  owner             String?
  price             Decimal        @db.Decimal(12, 2)
  maxPrice          Decimal?       @map("max_price") @db.Decimal(12, 2)
  minPrice          Decimal        @map("min_price") @db.Decimal(12, 2)
  commission        Decimal        @db.Decimal(5, 2)
  salePrice         Decimal?       @map("sale_price") @db.Decimal(12, 2)
  isPublic          Boolean        @default(true) @map("is_public")
  facebookUrl       String?        @map("facebook_url")
  tiktokUrl         String?        @map("tiktok_url")
  instagramUrl      String?        @map("instagram_url")
  youtubeUrl        String?        @map("youtube_url")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  isActive          Boolean        @default(true) @map("is_active")
  isFeatured        Boolean        @default(false) @map("is_featured")
  advisor           User           @relation(fields: [advisorId], references: [id])
  files             PropertyFile[]

  @@index([code])
  @@map("properties")
}

model File {
  id            String         @id @default(uuid()) @db.Uuid
  originalName  String         @map("original_name")
  fileName      String         @map("file_name")
  path          String
  size          Int
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  configuration Configuration?
  propertyFiles PropertyFile[]

  @@map("files")
}

model Configuration {
  id               String   @id @default(uuid()) @db.Uuid
  logoId           String?  @unique @map("logo_id") @db.Uuid
  companyName      String   @map("company_name")
  businessName     String   @map("business_name")
  ruc              String
  phone            String
  email            String?
  facebookProfile  String?  @map("facebook_profile")
  instagramProfile String?  @map("instagram_profile")
  youtubeProfile   String?  @map("youtube_profile")
  whatsappLink     String?  @map("whatsapp_link")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  logo             File?    @relation(fields: [logoId], references: [id])

  @@map("configurations")
}

model PropertyFile {
  propertyId String   @map("property_id") @db.Uuid
  fileId     String   @map("file_id") @db.Uuid
  fileType   FileType @map("file_type")
  createdAt  DateTime @default(now()) @map("created_at")
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, fileId])
  @@map("property_files")
}

enum UserType {
  ADMIN
  ACCOUNTING
  EMPLOYEE
}

enum PropertyType {
  Casa
  Terreno
  Casa_y_terreno @map("Casa y terreno")
  Departamento
  Finca
  Lote
}

enum Topography {
  Plano
  Semiplano
  Pendiente
  Mixto
}

enum Zone {
  Rural
  Urbano
  Urbanizacion @map("Urbanización")
}

enum PropertyStatus {
  Nuevo
  Negociacion @map("Negociación")
  Vendido
}

enum FileType {
  image
  document
}
