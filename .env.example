# Environment
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/realestate_db?schema=public"

# Authentication (JWT)
JWT_SECRET="super-secret-key-change-this"
JWT_EXPIRATION="1d"

# AWS S3 (File Storage)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_BUCKET_NAME="your-bucket-name"

# Mail Configuration (Optional)
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="user@example.com"
MAIL_PASSWORD="password"
MAIL_FROM="noreply@example.com"
MAIL_FROM_NAME="Bryan RealState"
MAIL_SECURE=false
MAIL_REQUIRE_TLS=true
MAIL_IGNORE_TLS=false
MAIL_TLS_REJECT_UNAUTHORIZED=true

# Company Config
COMPANY_NAME="Inmobiliaria Bryan"

# Google Contacts Sync
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
GOOGLE_API_KEY=""
GOOGLE_SCOPE="https://www.googleapis.com/auth/contacts"
CONTACTS_SYNC_CRON="0 */6 * * *"

# n8n Agent Router
# Base URL only. The backend appends /agent-http-router automatically.
N8N_RECOMMENDER_URL="https://n8n.ecuadev.com/webhook-test"
N8N_RECOMMENDER_TIMEOUT_MS=12000

# n8n JWT Authentication
N8N_JWT_SECRET="secure-key"
N8N_JWT_ALGORITHM="HS256"
N8N_JWT_EXPIRES_IN=""